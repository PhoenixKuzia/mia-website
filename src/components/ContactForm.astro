---
import { Mail, MessageCircle, Send } from '@lucide/astro';
---

<section class="section">
  <div class="container grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
    <div>
      <p class="mb-3 text-sm font-extrabold uppercase tracking-widest text-brand-primary">Kontakt</p>
      <h1 class="font-display text-4xl font-bold leading-tight text-brand-dark md:text-5xl">Schildern Sie kurz, was Sie gestalten lassen möchten.</h1>
      <p class="mt-4 text-base leading-7 text-slate-700">
        Für Launch ist das Formular als Netlify-kompatibles Static-Formular vorbereitet. Bei Vercel oder Cloudflare Pages kann die Action später auf Formspree gesetzt werden.
      </p>
      <div class="mt-8 grid gap-3">
        <a href="https://wa.me/PHONE_NUMBER" class="focus-ring inline-flex items-center gap-3 rounded-2xl bg-white/84 px-5 py-4 font-bold shadow-sm hover:shadow-bloom">
          <MessageCircle class="text-brand-primary" size={22} aria-hidden="true" /> WhatsApp Business
        </a>
        <a href="mailto:hallo@mia-design.de" class="focus-ring inline-flex items-center gap-3 rounded-2xl bg-white/84 px-5 py-4 font-bold shadow-sm hover:shadow-bloom">
          <Mail class="text-brand-primary" size={22} aria-hidden="true" /> hallo@mia-design.de
        </a>
      </div>
    </div>

    <form name="kontakt" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="rounded-[2rem] border border-brand-primary/12 bg-white/88 p-5 shadow-bloom sm:p-8">
      <input type="hidden" name="form-name" value="kontakt" />
      <p class="hidden">
        <label>Nicht ausfüllen <input name="bot-field" /></label>
      </p>
      <div class="grid gap-5">
        <label class="grid gap-2 text-sm font-bold text-brand-dark">
          Name
          <input required name="name" autocomplete="name" class="focus-ring rounded-2xl border border-brand-primary/18 bg-brand-cream px-4 py-3 font-normal" />
        </label>
        <label class="grid gap-2 text-sm font-bold text-brand-dark">
          E-Mail
          <input required type="email" name="email" autocomplete="email" class="focus-ring rounded-2xl border border-brand-primary/18 bg-brand-cream px-4 py-3 font-normal" />
        </label>
        <label class="grid gap-2 text-sm font-bold text-brand-dark">
          Projektart
          <select name="project_type" class="focus-ring rounded-2xl border border-brand-primary/18 bg-brand-cream px-4 py-3 font-normal">
            <option>Logo Design</option>
            <option>Icon Set</option>
            <option>Illustration</option>
            <option>Noch unsicher</option>
          </select>
        </label>
        <label class="grid gap-2 text-sm font-bold text-brand-dark">
          Nachricht
          <textarea required name="message" rows="6" class="focus-ring rounded-2xl border border-brand-primary/18 bg-brand-cream px-4 py-3 font-normal"></textarea>
        </label>
        <button type="submit" class="focus-ring inline-flex items-center justify-center gap-2 rounded-full bg-brand-primary px-6 py-4 font-bold text-white shadow-bloom transition hover:bg-brand-accent">
          Anfrage senden <Send size={18} aria-hidden="true" />
        </button>
      </div>
    </form>
  </div>
</section>
