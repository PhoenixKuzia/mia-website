---
const sideFlowers = Array.from({ length: 10 }, (_, index) => ({
  side: index % 2 === 0 ? 'left' : 'right',
  top: `${8 + index * 9}%`,
  delay: `${index * 0.65}s`,
  duration: `${5.5 + (index % 3) * 1.2}s`,
  size: 22 + (index % 4) * 6,
  hue: index % 3,
}));

const rainFlowers = Array.from({ length: 14 }, (_, index) => ({
  left: `${4 + index * 6.8}%`,
  delay: `${index * 0.9}s`,
  duration: `${9 + (index % 5) * 1.4}s`,
  size: 14 + (index % 4) * 5,
  hue: (index + 1) % 3,
}));

const hues = [
  'text-brand-primary',
  'text-brand-secondary',
  'text-brand-leaf',
] as const;
---

<div class="about-flowers pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
  {
    sideFlowers.map((flower) => (
      <span
        class:list={[
          'about-flower-side absolute opacity-70',
          hues[flower.hue],
          flower.side === 'left' ? 'left-0 -translate-x-1/3' : 'right-0 translate-x-1/3',
        ]}
        style={`top: ${flower.top}; animation-delay: ${flower.delay}; animation-duration: ${flower.duration}; width: ${flower.size}px; height: ${flower.size}px;`}
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="h-full w-full drop-shadow-sm">
          <circle cx="12" cy="8" r="3.5" />
          <ellipse cx="12" cy="14" rx="4" ry="5" transform="rotate(0 12 14)" />
          <ellipse cx="12" cy="14" rx="4" ry="5" transform="rotate(72 12 14)" />
          <ellipse cx="12" cy="14" rx="4" ry="5" transform="rotate(144 12 14)" />
          <ellipse cx="12" cy="14" rx="4" ry="5" transform="rotate(216 12 14)" />
          <ellipse cx="12" cy="14" rx="4" ry="5" transform="rotate(288 12 14)" />
          <path d="M12 18v5" stroke="currentColor" stroke-width="1.5" fill="none" />
        </svg>
      </span>
    ))
  }
  {
    rainFlowers.map((flower) => (
      <span
        class:list={['about-flower-rain absolute opacity-55', hues[flower.hue]]}
        style={`left: ${flower.left}; animation-delay: ${flower.delay}; animation-duration: ${flower.duration}; width: ${flower.size}px; height: ${flower.size}px;`}
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="h-full w-full">
          <circle cx="12" cy="7" r="3" />
          <ellipse cx="12" cy="13" rx="3.5" ry="4.5" transform="rotate(0 12 13)" />
          <ellipse cx="12" cy="13" rx="3.5" ry="4.5" transform="rotate(72 12 13)" />
          <ellipse cx="12" cy="13" rx="3.5" ry="4.5" transform="rotate(144 12 13)" />
          <ellipse cx="12" cy="13" rx="3.5" ry="4.5" transform="rotate(216 12 13)" />
          <ellipse cx="12" cy="13" rx="3.5" ry="4.5" transform="rotate(288 12 13)" />
        </svg>
      </span>
    ))
  }
</div>
