---
import { Menu, Sparkles } from '@lucide/astro';

const navItems = [
  { href: '/', label: 'Startseite' },
  { href: '/portfolio/', label: 'Portfolio' },
  { href: '/about/', label: 'Über MIA' },
  { href: '/blog/', label: 'Blog' },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-brand-dark text-white shadow-lg">
  <nav class="container flex min-h-20 items-center justify-between gap-4 py-3" aria-label="Hauptnavigation">
    <a href="/" class="focus-ring flex items-center gap-3 rounded-full" aria-label="MIA Startseite">
      <span class="grid h-12 w-12 place-items-center rounded-full bg-white">
        <img src="/assets/mia-logo.png" alt="" class="h-9 w-9 object-contain" />
      </span>
      <span class="font-display text-2xl font-bold tracking-normal">MIA</span>
    </a>

    <div class="hidden items-center gap-2 md:flex">
      {navItems.map((item) => (
        <a href={item.href} class="focus-ring rounded-full px-4 py-2 text-sm font-semibold text-white/82 transition hover:bg-white/10 hover:text-white">
          {item.label}
        </a>
      ))}
    </div>

    <a href="/contact/" class="focus-ring hidden items-center gap-2 rounded-full bg-brand-primary px-5 py-3 text-sm font-bold text-white shadow-bloom transition hover:bg-brand-accent md:inline-flex">
      <Sparkles size={18} aria-hidden="true" />
      Anfrage starten
    </a>

    <details class="group relative md:hidden">
      <summary class="focus-ring flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full bg-white/10">
        <Menu size={22} aria-hidden="true" />
        <span class="sr-only">Menü öffnen</span>
      </summary>
      <div class="absolute right-0 mt-3 w-64 rounded-2xl border border-white/10 bg-brand-dark p-3 shadow-2xl">
        {navItems.map((item) => (
          <a href={item.href} class="focus-ring block rounded-xl px-4 py-3 text-sm font-semibold text-white/86 hover:bg-white/10">
            {item.label}
          </a>
        ))}
        <a href="/contact/" class="focus-ring mt-2 flex items-center justify-center gap-2 rounded-xl bg-brand-primary px-4 py-3 text-sm font-bold text-white">
          <Sparkles size={18} aria-hidden="true" />
          Anfrage starten
        </a>
      </div>
    </details>
  </nav>
</header>
