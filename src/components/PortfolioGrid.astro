---
import { BadgeEuro, Brush, Gem, Shapes } from '@lucide/astro';

const services = [
  {
    title: 'Logo Design',
    category: 'Logos',
    price: 'ab 290 EUR',
    description: 'Markenzeichen, Farbwelt und einfache Varianten für Web, Social Media und Rechnung.',
    icon: Gem,
  },
  {
    title: 'Icon Sets',
    category: 'Icons',
    price: 'ab 120 EUR',
    description: 'Konsistente Icons für Websites, Präsentationen, Shops und digitale Produkte.',
    icon: Shapes,
  },
  {
    title: 'Illustrationen',
    category: 'Illustrationen',
    price: 'ab 160 EUR',
    description: 'Verspielte Motive, Charaktere und florale Grafiken für Content und Kampagnen.',
    icon: Brush,
  },
];
---

<section class="section" id="leistungen">
  <div class="container">
    <div class="mb-10 max-w-2xl">
      <p class="mb-3 text-sm font-extrabold uppercase tracking-widest text-brand-primary">Portfolio & Preise</p>
      <h2 class="font-display text-4xl font-bold leading-tight text-brand-dark md:text-5xl">Digitale Produkte, die sofort einsetzbar sind.</h2>
      <p class="mt-4 text-base leading-7 text-slate-700">
        Jedes Paket wird an den Stil, die Kanäle und den konkreten Einsatz angepasst. Die Preise dienen als Startpunkt für die Anfrage.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-3">
      {services.map((service, index) => {
        const Icon = service.icon;
        return (
          <article class="group rounded-[2rem] border border-brand-primary/12 bg-white/84 p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-bloom">
            <div class="mb-8 flex items-center justify-between gap-4">
              <span class="rounded-full bg-brand-light px-3 py-1 text-xs font-extrabold uppercase tracking-widest text-brand-primary">
                {service.category}
              </span>
              <span class:list={['grid h-14 w-14 place-items-center rounded-organic', index === 1 ? 'bg-brand-leaf/14 text-brand-leaf' : 'bg-brand-primary/12 text-brand-primary']}>
                <Icon size={28} aria-hidden="true" />
              </span>
            </div>
            <h3 class="text-2xl font-extrabold text-brand-dark">{service.title}</h3>
            <p class="mt-3 min-h-24 text-sm leading-7 text-slate-700">{service.description}</p>
            <div class="mt-6 flex items-center justify-between gap-4 border-t border-brand-primary/10 pt-5">
              <span class="inline-flex items-center gap-2 font-extrabold text-brand-dark">
                <BadgeEuro size={18} aria-hidden="true" /> {service.price}
              </span>
              <a href="/contact/" class="focus-ring rounded-full bg-brand-dark px-4 py-2 text-sm font-bold text-white transition hover:bg-brand-primary">Anfragen</a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
