---
const works = [
  {
    title: 'Nymara Fantasy',
    category: 'Logos',
    src: '/portfolio/Logo-Nymara-fantasy.svg',
    alt: 'Logo Nymara Fantasy',
  },
  {
    title: 'Wildpark Leipzig',
    category: 'Logos',
    src: '/portfolio/Logo-wildpark-leipzig.svg',
    alt: 'Logo Wildpark Leipzig',
  },
  {
    title: 'Pho-makes-IT',
    category: 'Logos',
    src: '/portfolio/Logo_Pho-makes-IT.svg',
    alt: 'Logo Pho-makes-IT',
  },
  {
    title: 'Sonne verspielt',
    category: 'Illustrationen',
    src: '/portfolio/Illustration-Sonne-verspielt.svg',
    alt: 'Illustration Sonne verspielt',
  },
  {
    title: 'Ahnenwolf Fantasy',
    category: 'Illustrationen',
    src: '/portfolio/Illustration-Ahnenwolf-fantasy-nymara.svg',
    alt: 'Illustration Ahnenwolf Fantasy Nymara',
  },
  {
    title: 'Shenron Fanart',
    category: 'Illustrationen',
    src: '/portfolio/Illustration-Shenron-fanart.svg',
    alt: 'Illustration Shenron Fanart',
  },
];
---

<section class="section bg-white/60" id="arbeiten">
  <div class="container">
    <div class="mb-10 max-w-2xl">
      <p class="mb-3 text-sm font-extrabold uppercase tracking-widest text-brand-primary">Ausgewählte Arbeiten</p>
      <h2 class="font-display text-4xl font-bold leading-tight text-brand-dark md:text-5xl">Logos und Illustrationen im Überblick.</h2>
      <p class="mt-4 text-base leading-7 text-slate-700">
        Eine Auswahl fertiger Motive – von Markenzeichen bis zu verspielten Illustrationen, jeweils als skalierbare SVG-Datei.
      </p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {works.map((work) => (
        <article class="group overflow-hidden rounded-[2rem] border border-brand-primary/12 bg-white/90 shadow-sm transition hover:-translate-y-1 hover:shadow-bloom">
          <div class="flex aspect-[4/3] items-center justify-center bg-brand-cream/80 p-6">
            <img
              src={work.src}
              alt={work.alt}
              class="max-h-full w-full object-contain transition duration-300 group-hover:scale-[1.02]"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="border-t border-brand-primary/10 px-5 py-4">
            <span class="rounded-full bg-brand-light px-3 py-1 text-xs font-extrabold uppercase tracking-widest text-brand-primary">
              {work.category}
            </span>
            <h3 class="mt-3 text-lg font-extrabold text-brand-dark">{work.title}</h3>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
