---
export const prerender = true;

import { getCollection } from 'astro:content';
import DefaultLayout from '../../layouts/DefaultLayout.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<DefaultLayout title="Blog | MIA" description="Blogbeiträge von MIA zu Logos, Icons, Illustrationen und digitaler Gestaltung.">
  <section class="section">
    <div class="container">
      <p class="mb-3 text-sm font-extrabold uppercase tracking-widest text-brand-primary">Blog</p>
      <h1 class="max-w-3xl font-display text-5xl font-extrabold leading-tight text-brand-dark md:text-6xl">Inspiration, Prozess und Designwissen.</h1>

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {posts.map((post) => (
          <article class="rounded-[2rem] border border-brand-primary/12 bg-white/86 p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-bloom">
            <time class="text-sm font-bold text-brand-primary" datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString('de-DE')}</time>
            <h2 class="mt-3 text-2xl font-extrabold text-brand-dark">{post.data.title}</h2>
            <p class="mt-3 text-sm leading-7 text-slate-700">{post.data.description}</p>
            <a href={`/blog/${post.id.replace(/\.md$/, '')}/`} class="focus-ring mt-6 inline-flex rounded-full bg-brand-dark px-5 py-3 text-sm font-bold text-white hover:bg-brand-primary">Lesen</a>
          </article>
        ))}
      </div>

      <nav class="mt-10 flex items-center justify-center gap-3" aria-label="Blog Pagination">
        <span class="rounded-full bg-brand-dark px-5 py-3 text-sm font-bold text-white">1</span>
      </nav>
    </div>
  </section>
</DefaultLayout>
