---
export { prerender } from '../prerender';

import DefaultLayout from '../layouts/DefaultLayout.astro';
---

<DefaultLayout title="Datenschutz | MIA" description="Datenschutzhinweise der MIA Website.">
  <section class="section">
    <div class="container max-w-3xl rounded-[2rem] bg-white/88 p-6 shadow-sm">
      <h1 class="font-display text-5xl font-extrabold">Datenschutz</h1>
      <p class="mt-6 leading-8 text-slate-700">
        Platzhalter für Datenschutzhinweise. Vor Launch müssen Hosting, Formularanbieter, Keystatic/GitHub-Anmeldung, Schrift-Einbindung und Kontaktwege rechtlich geprüft und beschrieben werden.
      </p>
      <h2 class="mt-8 text-2xl font-extrabold">Kontaktformular</h2>
      <p class="mt-3 leading-8 text-slate-700">
        Das Formular ist technisch vorbereitet. Die konkrete Verarbeitung hängt vom gewählten Formularanbieter ab.
      </p>
    </div>
  </section>
</DefaultLayout>
