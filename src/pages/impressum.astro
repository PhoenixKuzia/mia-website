---
import DefaultLayout from '../layouts/DefaultLayout.astro';
---

<DefaultLayout title="Impressum | MIA" description="Impressum der MIA Website.">
  <section class="section">
    <div class="container max-w-3xl rounded-[2rem] bg-white/88 p-6 shadow-sm">
      <h1 class="font-display text-5xl font-extrabold">Impressum</h1>
      <p class="mt-6 leading-8 text-slate-700">
        Platzhalter für rechtliche Angaben. Vor Veröffentlichung müssen Name, Anschrift, Kontaktangaben, Umsatzsteuer-ID falls vorhanden und weitere Pflichtangaben geprüft und ergänzt werden.
      </p>
      <div class="mt-8 grid gap-2 text-slate-700">
        <p><strong>MIA</strong></p>
        <p>Adresse ergänzen</p>
        <p>E-Mail: hallo@mia-design.de</p>
      </div>
    </div>
  </section>
</DefaultLayout>
