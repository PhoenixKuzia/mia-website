---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import { Brush, Flower2, Sparkles } from '@lucide/astro';
---

<DefaultLayout title="Über MIA" description="Über MIA: digitale Illustrationen, Logos und Icons mit organischem Stil.">
  <section class="section">
    <div class="container grid gap-10 md:grid-cols-[0.95fr_1.05fr] md:items-center">
      <div class="relative">
        <div class="rounded-organic bg-white/84 p-8 shadow-bloom">
          <img src="/assets/mia-logo.png" alt="MIA Logo" class="mx-auto h-72 w-72 object-contain" />
        </div>
      </div>
      <div>
        <p class="mb-3 text-sm font-extrabold uppercase tracking-widest text-brand-primary">Über MIA</p>
        <h1 class="font-display text-5xl font-extrabold leading-tight text-brand-dark md:text-6xl">Gestaltung mit Gefühl für Form, Farbe und Alltag.</h1>
        <p class="mt-6 text-base leading-8 text-slate-700">
          MIA verbindet digitale Illustration mit praktischer Markenarbeit. Der Fokus liegt auf Designs, die unverwechselbar wirken und zugleich leicht nutzbar bleiben: als Profilbild, Website-Grafik, Icon-System oder Logo-Datei.
        </p>
      </div>
    </div>
  </section>

  <section class="section bg-white/60">
    <div class="container grid gap-5 md:grid-cols-3">
      {[
        { icon: Flower2, title: 'Organische Bildsprache', text: 'Florale Formen, weiche Linien und lebendige Farben.' },
        { icon: Brush, title: 'Digitale Umsetzung', text: 'Dateien und Varianten, die direkt weiterverwendet werden können.' },
        { icon: Sparkles, title: 'Persönlicher Stil', text: 'Kein Baukastenlook, sondern Gestaltung passend zum Projekt.' },
      ].map((item) => {
        const Icon = item.icon;
        return (
          <article class="rounded-[2rem] bg-white/88 p-6 shadow-sm">
            <Icon class="mb-5 text-brand-primary" size={32} aria-hidden="true" />
            <h2 class="text-xl font-extrabold">{item.title}</h2>
            <p class="mt-3 text-sm leading-7 text-slate-700">{item.text}</p>
          </article>
        );
      })}
    </div>
  </section>
</DefaultLayout>
